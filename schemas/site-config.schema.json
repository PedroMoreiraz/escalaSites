{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "escalasites/site-config",
  "title": "Site Config",
  "description": "Central configuration object. Source of truth for brand, navigation, SEO, and design system.",
  "type": "object",
  "required": ["brand", "nav", "seo", "design"],
  "properties": {
    "brand": {
      "type": "object",
      "required": ["name", "tagline", "locale", "currency"],
      "properties": {
        "name": { "type": "string" },
        "tagline": { "type": "string" },
        "locale": { "type": "string" },
        "currency": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" }
      }
    },
    "nav": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "href"],
        "properties": {
          "label": { "type": "string" },
          "href": { "type": "string" }
        }
      }
    },
    "seo": {
      "type": "object",
      "required": ["title", "description", "canonical"],
      "properties": {
        "title": { "type": "string", "maxLength": 60 },
        "description": { "type": "string", "maxLength": 160 },
        "canonical": { "type": "string", "format": "uri" },
        "ogImage": { "type": "string" }
      }
    },
    "design": {
      "type": "object",
      "required": ["archetype", "accentColor", "variance", "motion", "density"],
      "properties": {
        "archetype": {
          "type": "string",
          "enum": ["Ethereal Glass", "Editorial Luxury", "Soft Structuralism", "Utilitarian Minimalism"]
        },
        "accentColor": { "type": "string", "description": "HSL or hex value of the single accent color." },
        "variance": { "type": "integer", "minimum": 1, "maximum": 10 },
        "motion": { "type": "integer", "minimum": 1, "maximum": 10 },
        "density": { "type": "integer", "minimum": 1, "maximum": 10 }
      }
    }
  }
}
